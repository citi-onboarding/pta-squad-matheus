generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Categoria {
  ROMANCE
  INFANTIL
  TECNOLOGIA
  HISTORIA
  CIENCIAS
}

enum StatusEmprestimo {
  EM_ANDAMENTO
  DEVOLVIDO
}

model Livro {
  id                   String       @id @default(uuid())
  titulo               String
  autor                String
  isbn                 String       @unique @db.VarChar(13)
  editora              String
  ano                  Int
  quantidadeTotal      Int
  quantidadeDisponivel Int
  categoria            Categoria
  createdAt            DateTime     @default(now())

  emprestimos Emprestimo[]

  @@map("livros")
}

model Emprestimo {
  id                    String            @id @default(uuid())
  livroId               String
  nomeCliente           String
  emailCliente          String
  dataLocacao           DateTime
  dataPrevistaDevolucao DateTime
  status                StatusEmprestimo  @default(EM_ANDAMENTO)
  createdAt             DateTime          @default(now())

  livro Livro @relation(fields: [livroId], references: [id])

  @@map("emprestimos")
}